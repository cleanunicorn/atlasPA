# ── Agent identity ────────────────────────────────────────────────────────────
AGENT_NAME=Atlas
AGENT_TIMEZONE=UTC

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supported: anthropic, openai, ollama, openrouter
LLM_PROVIDER=ollama

# ── Anthropic (Claude) ────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── OpenAI (GPT) ─────────────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o
# OPENAI_BASE_URL=            # Optional: override for Azure or compatible APIs

# ── OpenRouter ────────────────────────────────────────────────────────────────
# OPENROUTER_API_KEY=sk-or-your-key-here
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-5

# ── Ollama (local models) ─────────────────────────────────────────────────────
OLLAMA_MODEL=qwen3.5:9b-q8_0
OLLAMA_BASE_URL=http://localhost:11434/v1

# ── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=APIKEY
# Comma-separated Telegram user IDs allowed to use the bot (security gate)
# Leave empty to allow anyone (not recommended for public bots)
TELEGRAM_ALLOWED_USERS=12341234

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO   # DEBUG for verbose output
